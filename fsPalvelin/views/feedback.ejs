<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
  </head>
  <body>   <table>
    <tr><th>Date</th><th>From</th><th>Feedback</th></tr>
    <% for (const row of rows) { %>
        <tr>
            <td><%= row.arrived %></td>
            <td><%= row.guest_name %> (<%= row.guest_email %>)</td>
            <td><%= row.feedback %></td>
</tr>
    <% } %>
    </table></body>
</html>